<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Panel — Kryonix</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="/style.css">
</head>
<body>
<div class="container mobile-app-layout">
    <div class="main-content mobile-panel">
        <div class="mobile-page-header">
            <a href="/chat" class="back-button"><i class="fas fa-arrow-left"></i> Back</a>
            <h3 class="page-title">Admin Panel</h3>
            <span aria-hidden="true" style="width:4rem;"></span>
        </div>

        <% if (message) { %>
        <div class="alert alert-<%= message_type === 'success' ? 'success' : 'error' %>" role="alert" style="margin:16px 24px 0;">
            <%= message %>
        </div>
        <% } %>

        <!-- Delete User -->
        <div class="section">
            <h3><i class="fas fa-user-times"></i> Delete User</h3>
            <form action="/admin" method="POST">
                <input type="hidden" name="action" value="delete_user">
                <div class="mb-3">
                    <label for="delete_username" class="form-label">Username</label>
                    <input type="text" class="form-control" id="delete_username" name="target_username" placeholder="Enter username to delete" required>
                </div>
                <button type="submit" class="button danger-button"><i class="fas fa-trash"></i> Delete User</button>
            </form>
        </div>

        <!-- Timeout User -->
        <div class="section">
            <h3><i class="fas fa-hourglass-half"></i> Timeout User</h3>
            <form action="/admin" method="POST">
                <input type="hidden" name="action" value="timeout">
                <div class="mb-3">
                    <label for="timeout_username" class="form-label">Username</label>
                    <input type="text" class="form-control" id="timeout_username" name="target_username" placeholder="Enter username" required>
                </div>
                <div class="mb-3">
                    <label for="timeout_minutes" class="form-label">Minutes</label>
                    <input type="number" class="form-control" id="timeout_minutes" name="minutes" placeholder="Duration in minutes" min="1" required>
                </div>
                <button type="submit" class="button"><i class="fas fa-clock"></i> Apply Timeout</button>
            </form>
        </div>

        <!-- Untimeout User -->
        <div class="section">
            <h3><i class="fas fa-hourglass-end"></i> Remove Timeout</h3>
            <form action="/admin" method="POST">
                <input type="hidden" name="action" value="untimeout">
                <div class="mb-3">
                    <label for="untimeout_username" class="form-label">Username</label>
                    <input type="text" class="form-control" id="untimeout_username" name="target_username" placeholder="Enter username" required>
                </div>
                <button type="submit" class="button"><i class="fas fa-check"></i> Remove Timeout</button>
            </form>
        </div>

        <!-- Ban User -->
        <div class="section">
            <h3><i class="fas fa-ban"></i> Ban User</h3>
            <form action="/admin" method="POST">
                <input type="hidden" name="action" value="ban_user">
                <div class="mb-3">
                    <label for="ban_username" class="form-label">Username</label>
                    <input type="text" class="form-control" id="ban_username" name="target_username" placeholder="Enter username to ban" required>
                </div>
                <button type="submit" class="button danger-button"><i class="fas fa-ban"></i> Ban User</button>
            </form>
        </div>

        <!-- Unban Email -->
        <div class="section">
            <h3><i class="fas fa-unlock"></i> Unban Email</h3>
            <form action="/admin" method="POST">
                <input type="hidden" name="action" value="unban_email">
                <div class="mb-3">
                    <label for="unban_email" class="form-label">Email Address</label>
                    <input type="email" class="form-control" id="unban_email" name="target_email" placeholder="Enter email to unban" required>
                </div>
                <button type="submit" class="button"><i class="fas fa-check"></i> Unban Email</button>
            </form>
        </div>

        <!-- Change Password -->
        <div class="section">
            <h3><i class="fas fa-key"></i> Change User Password</h3>
            <form action="/admin" method="POST">
                <input type="hidden" name="action" value="change_password">
                <div class="mb-3">
                    <label for="pw_username" class="form-label">Username</label>
                    <input type="text" class="form-control" id="pw_username" name="target_username" placeholder="Enter username" required>
                </div>
                <div class="mb-3">
                    <label for="new_password" class="form-label">New Password</label>
                    <input type="password" class="form-control" id="new_password" name="new_password" placeholder="Enter new password" minlength="6" required>
                </div>
                <button type="submit" class="button"><i class="fas fa-key"></i> Change Password</button>
            </form>
        </div>

        <!-- Banned Emails List -->
        <div class="section">
            <h3><i class="fas fa-list-alt"></i> Banned Emails (<%= banned_list ? banned_list.length : 0 %>)</h3>
            <% if (banned_list && banned_list.length > 0) { %>
            <ul style="list-style:none;padding:0;">
                <% banned_list.forEach(function(email) { %>
                <li style="padding:8px 0;border-bottom:1px solid var(--border-color);display:flex;justify-content:space-between;align-items:center;">
                    <span><i class="fas fa-ban" style="color:var(--danger);margin-right:8px;"></i> <%= email %></span>
                </li>
                <% }); %>
            </ul>
            <% } else { %>
            <p style="opacity:0.6;">No banned emails.</p>
            <% } %>
        </div>
    </div>
</div>
</body>
</html>
