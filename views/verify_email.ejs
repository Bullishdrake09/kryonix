<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Verify Email – Kryonix</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body class="auth-page">
    <div class="auth-container">
        <% if (verified) { %>
        <div class="success-icon">✓</div>
        <h2 class="success-title">Email Verified!</h2>
        <p class="success-body">
            Your email address has been confirmed.<br>
            You can now <strong>log in</strong> to your Kryonix account.
        </p>
        <a href="/login" class="btn-login">Go to Login →</a>
        <% } else { %>
        <h2>Verify Your Email</h2>
        <p class="info-text">
            We sent a 6-digit code to <strong><%= masked_email %></strong>.<br>
            Enter it below to activate your account.
        </p>
        <% if (typeof error !== 'undefined' && error) { %>
            <p class="error-message"><%= error %></p>
        <% } %>
        <form action="/verify-email" method="post">
            <input type="text" name="code" class="code-input"
                   placeholder="000000" maxlength="6"
                   inputmode="numeric" autocomplete="one-time-code" required>
            <button type="submit">Verify Email</button>
        </form>
        <a class="resend-link" href="/verify-email/resend">
            Didn't receive a code? Resend
        </a>
        <% } %>
    </div>
</body>
</html>
