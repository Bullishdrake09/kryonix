{
  "name": "kryonix-backend",
  "version": "2.0.0",
  "description": "Kryonix secure chat backend — Signal Protocol E2EE + WebRTC signaling + Ollama AI gateway",
  "main": "server.js",
  "engines": { "node": ">=18.0.0" },
  "scripts": {
    "start":   "node server.js",
    "dev":     "nodemon server.js",
    "test":    "jest --coverage",
    "lint":    "eslint . --ext .js",
    "migrate": "node db/database.js"
  },
  "dependencies": {
    "bcrypt":              "^5.1.1",
    "compression":         "^1.7.4",
    "cors":                "^2.8.5",
    "express":             "^4.18.2",
    "express-rate-limit":  "^7.1.5",
    "helmet":              "^7.1.0",
    "joi":                 "^17.11.0",
    "jsonwebtoken":        "^9.0.2",
    "knex":                "^3.1.0",
    "morgan":              "^1.10.0",
    "sqlite3":             "^5.1.6",
    "uuid":                "^9.0.0",
    "winston":             "^3.11.0",
    "ws":                  "^8.16.0"
  },
  "devDependencies": {
    "eslint":    "^8.56.0",
    "jest":      "^29.7.0",
    "nodemon":   "^3.0.3",
    "supertest": "^6.3.4"
  },
  "optionalDependencies": {
    "pg": "^8.11.3"
  }
}
