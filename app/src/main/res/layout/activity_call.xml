<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary">

    <!-- Remote video fills the screen -->
    <org.webrtc.SurfaceViewRenderer
        android:id="@+id/remoteSurfaceView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Local video pip -->
    <org.webrtc.SurfaceViewRenderer
        android:id="@+id/localSurfaceView"
        android:layout_width="120dp"
        android:layout_height="160dp"
        android:layout_gravity="top|end"
        android:layout_margin="16dp" />

    <!-- Audio call icon (shown when video is off) -->
    <ImageView
        android:id="@+id/ivCallTypeIcon"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_gravity="center"
        android:src="@drawable/ic_call"
        android:tint="@color/accent"
        android:visibility="gone" />

    <!-- Top info overlay -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingTop="60dp"
        android:paddingHorizontal="24dp"
        android:background="@drawable/gradient_top">

        <TextView
            android:id="@+id/tvRemoteUser"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvCallStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/on_surface_variant"
            android:textSize="14sp"
            android:layout_marginTop="6dp" />

    </LinearLayout>

    <!-- Incoming call controls (accept/decline) -->
    <LinearLayout
        android:id="@+id/llIncomingControls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingBottom="60dp"
        android:paddingHorizontal="48dp"
        android:visibility="gone">

        <ImageButton
            android:id="@+id/btnDecline"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:background="@drawable/bg_call_btn_red"
            android:src="@drawable/ic_call_end"
            android:tint="@color/white"
            android:padding="18dp"
            android:layout_marginEnd="48dp" />

        <ImageButton
            android:id="@+id/btnAccept"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:background="@drawable/bg_call_btn_green"
            android:src="@drawable/ic_call"
            android:tint="@color/white"
            android:padding="18dp" />

    </LinearLayout>

    <!-- Active call controls -->
    <LinearLayout
        android:id="@+id/llCallControls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingBottom="48dp"
        android:paddingHorizontal="16dp"
        android:visibility="gone">

        <ImageButton
            android:id="@+id/btnToggleMute"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@drawable/bg_call_btn_dark"
            android:src="@drawable/ic_mic_on"
            android:tint="@color/white"
            android:padding="14dp"
            android:layout_margin="8dp" />

        <ImageButton
            android:id="@+id/btnToggleCamera"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@drawable/bg_call_btn_dark"
            android:src="@drawable/ic_cam_on"
            android:tint="@color/white"
            android:padding="14dp"
            android:layout_margin="8dp" />

        <ImageButton
            android:id="@+id/btnEndCall"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:background="@drawable/bg_call_btn_red"
            android:src="@drawable/ic_call_end"
            android:tint="@color/white"
            android:padding="16dp"
            android:layout_margin="8dp" />

        <ImageButton
            android:id="@+id/btnSwitchCamera"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@drawable/bg_call_btn_dark"
            android:src="@drawable/ic_switch_camera"
            android:tint="@color/white"
            android:padding="14dp"
            android:layout_margin="8dp" />

    </LinearLayout>

</FrameLayout>
